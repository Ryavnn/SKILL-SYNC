# ═══════════════════════════════════════════════════════════════
# M-PESA CONFIGURATION (Safaricom Daraja API)
# ═══════════════════════════════════════════════════════════════

# Environment: 'sandbox' or 'production'
MPESA_ENVIRONMENT=sandbox

# Consumer Key and Secret from Safaricom Daraja Portal
# Get these from: https://developer.safaricom.co.ke/MyApps
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Lipa Na M-Pesa Online Passkey
# Get this from your app's Test Credentials in Daraja Portal
MPESA_PASSKEY=your_passkey_here

# Business Shortcode (Paybill or Till Number)
# Sandbox default: 174379
# Production: Your actual shortcode
MPESA_SHORTCODE=174379

# Callback URL (must be publicly accessible HTTPS endpoint)
# Safaricom will POST payment results to this URL
# For local development, use ngrok or similar tunneling service:
#   ngrok http 5000
#   Then use: https://your-ngrok-url.ngrok.io/api/payments/mpesa/callback
# 
# Production example:
#   https://skillsync.co.ke/api/payments/mpesa/callback
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/payments/mpesa/callback


# ═══════════════════════════════════════════════════════════════
# TESTING CREDENTIALS (Sandbox)
# ═══════════════════════════════════════════════════════════════

# Sandbox Test Phone Number: 254708374149
# Any amount between 1 and 70,000 will succeed
# Any amount above 70,000 will fail

# Sandbox Test Credentials:
# - Consumer Key: Get from Daraja Portal
# - Consumer Secret: Get from Daraja Portal
# - Passkey: Get from Daraja Portal Test Credentials
# - Shortcode: 174379 (default sandbox shortcode)

# ═══════════════════════════════════════════════════════════════
# PRODUCTION SETUP CHECKLIST
# ═══════════════════════════════════════════════════════════════

# ✅ 1. Register Lipa Na M-Pesa Online on Daraja Portal
# ✅ 2. Get production Consumer Key and Secret
# ✅ 3. Get production Passkey
# ✅ 4. Use your actual Paybill/Till number as SHORTCODE
# ✅ 5. Setup production callback URL (MUST be HTTPS)
# ✅ 6. Whitelist your callback URL with Safaricom
# ✅ 7. Test with small amounts first
# ✅ 8. Set MPESA_ENVIRONMENT=production
